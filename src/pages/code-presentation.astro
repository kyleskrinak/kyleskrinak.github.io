---
// Redirect old Jekyll URL to new Astro URL using static HTML redirect pattern
import { SITE } from '@/config';

const target = '/presentations/code-presentation.html';
const canonicalUrl = new URL(target.slice(1), SITE.website).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>Redirecting…</title>
    <meta name="robots" content="noindex">
    <link rel="canonical" href={canonicalUrl}>
    <meta http-equiv="refresh" content={`0;url=${target}`}>
  </head>
  <body>
    <p>
      Redirecting to <a href={target}>{target}</a>.
    </p>
  </body>
</html>
