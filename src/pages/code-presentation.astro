---
// Redirect old Jekyll URL to new Astro URL using static HTML redirect pattern
const target = '/presentations/code-presentation.html';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>Redirecting…</title>
    <meta name="robots" content="noindex">
    <link rel="canonical" href={target}>
    <meta http-equiv="refresh" content={`0;url=${target}`}>
  </head>
  <body>
    <p>
      Redirecting to <a href={target}>{target}</a>.
    </p>
  </body>
</html>
