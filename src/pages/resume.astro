---
import { getEntry, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { linkWithBase } from "@/utils/linkWithBase";
import "@/styles/resume.css";

const page = await getEntry("pages", "resume");
if (!page) throw new Error("Resume page not found");

const { Content } = await render(page);
const { title, description, contactEmail, contactWebsite, contactLinkedin } = page.data;
---

{/* Content title already carries the site owner's name — no SITE.title
    suffix, which would render "Kyle Skrinak — Resume | Kyle Skrinak" */}
<Layout
  title={title}
  description={description}
>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout pb-12">
    <div class="resume-header">
      <h1 class="text-2xl font-semibold sm:text-3xl">{title}</h1>
      <div class="contact-info">
        {contactEmail && (
          <span><a href={`mailto:${contactEmail}`}>{contactEmail}</a></span>
        )}
        {contactWebsite && (
          <span><a href={contactWebsite}>{contactWebsite.replace(/^https?:\/\//, "")}</a></span>
        )}
        {contactLinkedin && (
          <span><a href={contactLinkedin}>LinkedIn</a></span>
        )}
      </div>
      <p class="resume-download mt-4">
        <a href={linkWithBase("/resume/kyle-skrinak-resume.pdf")}>Download PDF</a>
        — a one-page, print-formatted copy of this resume.
      </p>
    </div>
    <article class="resume-content mt-8">
      <Content />
    </article>
  </main>
  <Footer />
</Layout>
