---
import { getCollection } from 'astro:content';
import { getPath } from '@/utils/getPath';
import { SITE } from '@/config';

/**
 * Dynamic redirect route for Jekyll URL format
 *
 * Maps old Jekyll URLs:
 *   /2025/09/19/modernizing-an-old-jekyll-blog/
 *
 * To new Astro URLs:
 *   /posts/2025-09-19-modernizing-an-old-jekyll-blog/
 *
 * Returns 301 permanent redirects for SEO (meta refresh in static builds)
 */

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map(post => {
    // Post ID format: "2025-09-19-modernizing-an-old-jekyll-blog"
    const parts = post.id.split('-');

    // Extract year, month, day
    const year = parts[0];
    const month = parts[1];
    const day = parts[2];

    // Join remaining parts as slug
    const postSlug = parts.slice(3).join('-');

    return {
      params: {
        year,
        month,
        day,
        slug: postSlug,
      },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { year, month, day, slug } = Astro.params;

// Build new and old URLs
const newUrl = getPath(post.id, post.filePath);
const oldUrl = `/${year}/${month}/${day}/${slug}/`;
const canonicalUrl = new URL(newUrl, SITE.website).href;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Redirecting to: {newUrl}</title>
  <meta http-equiv="refresh" content={`0;url=${newUrl}`}>
  <meta name="robots" content="noindex">
  <link rel="canonical" href={canonicalUrl}>
</head>
<body>
  <a href={newUrl}>
    Redirecting from <code>{oldUrl}</code> to <code>{newUrl}</code>
  </a>
</body>
</html>
