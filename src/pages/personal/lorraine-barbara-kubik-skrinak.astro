---
// Redirect old Jekyll URL to new Astro URL using static HTML redirect pattern
import { SITE } from '@/config';

const redirectTo = '/posts/2019-10-31-lorraine-barbara-kubik-skrinak/';
const canonicalUrl = new URL(redirectTo.slice(1), SITE.website).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>Redirecting…</title>
    <meta name="robots" content="noindex">
    <link rel="canonical" href={canonicalUrl}>
    <meta http-equiv="refresh" content={`0;url=${redirectTo}`}>
  </head>
  <body>
    <p>Redirecting to <a href={redirectTo}>{redirectTo}</a>…</p>
  </body>
</html>
