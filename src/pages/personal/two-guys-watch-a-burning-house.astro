---
// Redirect old Jekyll URL to new Astro URL using static HTML redirect pattern
import { SITE } from '@/config';
import { createPath } from '@/config/consts';

const destination = '/posts/2021-01-18-two-guys-watch-a-burning-house/';
const canonicalUrl = new URL(destination.slice(1), SITE.website).href;
const redirectUrl = createPath(destination);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>Redirecting…</title>
    <meta name="robots" content="noindex">
    <link rel="canonical" href={canonicalUrl}>
    <meta http-equiv="refresh" content={`0;url=${redirectUrl}`}>
  </head>
  <body>
    <p>
      Redirecting to
      <a href={redirectUrl}>{redirectUrl}</a>.
    </p>
  </body>
</html>
