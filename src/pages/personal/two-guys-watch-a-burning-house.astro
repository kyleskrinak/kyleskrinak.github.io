---
// Redirect old Jekyll URL to new Astro URL using static HTML redirect pattern
const destination = '/posts/2021-01-18-two-guys-watch-a-burning-house/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>Redirecting…</title>
    <meta name="robots" content="noindex">
    <link rel="canonical" href={destination}>
    <meta http-equiv="refresh" content={`0;url=${destination}`}>
  </head>
  <body>
    <p>
      Redirecting to
      <a href={destination}>{destination}</a>.
    </p>
  </body>
</html>
