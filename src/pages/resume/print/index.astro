---
import { getEntry, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import "@/styles/resume.css";

const page = await getEntry("pages", "resume");
if (!page) throw new Error("Resume page not found");

const { Content } = await render(page);
const { title, description, contactEmail, contactWebsite, contactLinkedin, contactAddress } = page.data;
---

{/* Canonical points at the public /resume/ page: this route is a noindex
    PDF-rendering source and must not declare itself canonical. Title drops
    the SITE.title suffix — the content title already carries the name. */}
<Layout
  title={title}
  description={description}
  noindex={true}
  canonicalURL={new URL("/resume/", Astro.site).href}
>
  <main id="main-content" class="app-layout pb-12">
    <div class="resume-header">
      <h1 class="text-2xl font-semibold sm:text-3xl">{title}</h1>
      <div class="contact-info">
        {contactEmail && (
          <span><a href={`mailto:${contactEmail}`}>{contactEmail}</a></span>
        )}
        {contactAddress && <span>{contactAddress}</span>}
        {contactWebsite && (
          <span><a href={contactWebsite}>{contactWebsite.replace(/^https?:\/\//, "")}</a></span>
        )}
        {contactLinkedin && (
          <span><a href={contactLinkedin}>{contactLinkedin.replace(/^https?:\/\//, "")}</a></span>
        )}
      </div>
    </div>
    <article class="resume-content mt-8">
      <Content />
    </article>
  </main>
</Layout>
