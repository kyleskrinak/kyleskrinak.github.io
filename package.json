{
  "name": "astro-paper",
  "type": "module",
  "version": "5.5.1",
  "engines": {
    "node": ">=22.22.2"
  },
  "packageManager": "npm@12.0.1",
  "scripts": {
    "dev": "astro dev",
    "lint:resume": "node scripts/lint-resume.mjs",
    "build": "node scripts/check-image-conventions.mjs --all && node scripts/lint-resume.mjs && astro build && pagefind --site dist && cp -r dist/_pagefind public/",
    "build:ci": "node scripts/check-image-conventions.mjs --all && node scripts/lint-resume.mjs && astro build && pagefind --site dist",
    "build:presentations": "node scripts/build-presentations.js",
    "check:images": "node scripts/check-image-conventions.mjs --all",
    "new-post": "node scripts/new-post.mjs",
    "resume:variant": "node scripts/build-resume-variant.mjs",
    "archive:pdf": "node scripts/build-archive-pdf.mjs",
    "archive:presentations": "node scripts/build-presentations-pdf.mjs",
    "preview": "astro preview",
    "sync": "astro sync",
    "astro": "astro",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:md": "markdownlint-cli2",
    "test": "playwright test",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "test:visual": "playwright test --project=visual-*",
    "test:visual:baseline": "playwright test --project=visual-* --update-snapshots",
    "test:visual:report": "playwright show-report",
    "test:seo": "playwright test --project=seo",
    "test:analytics": "playwright test --project=analytics",
    "test:console": "playwright test --project=console",
    "test:links": "playwright test --project=links",
    "test:staging": "cross-env PLAYWRIGHT_TEST_BASE_URL=https://kyleskrinak.github.io playwright test",
    "test:production": "cross-env PLAYWRIGHT_TEST_BASE_URL=https://kyle.skrinak.com playwright test",
    "htmltest": "htmltest",
    "htmltest:verbose": "htmltest -l 3",
    "check:links": "node scripts/check-links.js",
    "audit:deps": "node scripts/audit-deps.mjs",
    "config:generate": "node config/generate-docs.mjs",
    "config:validate": "node config/validate.mjs",
    "config:inspect": "node config/inspect.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.0",
    "dayjs": "^1.11.19",
    "lodash.kebabcase": "^4.1.1",
    "remark-collapse": "^0.1.2",
    "remark-directive": "^4.0.0",
    "remark-toc": "^9.0.0",
    "satori": "^0.26.0",
    "sharp": "^0.35.0",
    "slugify": "^1.6.6",
    "tailwindcss": "^4.3.2",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@pagefind/default-ui": "^1.5.2",
    "@playwright/test": "^1.60.0",
    "@shikijs/transformers": "^4.1.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/lodash.kebabcase": "^4.1.9",
    "@typescript-eslint/parser": "^8.59.4",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.0",
    "eslint-plugin-astro": "^3.0.0",
    "github-slugger": "^2.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "linkedom": "^0.18.13",
    "markdown-it": "^14.2.0",
    "markdownlint-cli2": "^0.23.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sanitize-html": "^2.17.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.4",
    "yaml": "^2.9.0"
  },
  "overrides": {
    "devalue": "5.8.1",
    "fast-uri": "4.1.0",
    "fast-xml-builder": "1.3.0",
    "fast-xml-parser": "5.9.3",
    "flatted": "3.4.2",
    "brace-expansion": "5.0.7",
    "postcss": "8.5.19"
  }
}
